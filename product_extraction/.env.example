# ===========================================
# Scraper Configuration
# ===========================================

# Chrome Driver Settings
HEADLESS_MODE=false
MAX_SCROLLS=15
PAGE_TIMEOUT=20

# ===========================================
# Logging Configuration
# ===========================================

LOG_LEVEL=INFO

# ===========================================
# Database Configuration (Optional)
# ===========================================

DB_HOST=localhost
DB_PORT=5432
DB_NAME=products
DB_USER=admin
DB_PASSWORD=

# ===========================================
# Notification Settings (Optional)
# ===========================================

# Telegram Bot
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Email (Future)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=

# ===========================================
# Advanced Settings
# ===========================================

# Rate Limiting
REQUESTS_PER_MINUTE=10

# Retry Settings
MAX_RETRIES=3
RETRY_DELAY=5

# Cache Settings
ENABLE_CACHE=true
CACHE_EXPIRY=3600
